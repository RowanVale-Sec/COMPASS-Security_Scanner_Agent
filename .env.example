# =============================================================================
# COMPASS - Environment Configuration Template
# =============================================================================
# Copy this file to .env for local dev. The API gateway's /api/scan endpoint
# now accepts per-request LLM credentials, so secrets no longer need to live
# here — only platform/runtime knobs. The variables below are all OPTIONAL
# unless explicitly marked.
# =============================================================================

# -----------------------------------------------------------------------------
# Deduplication tuning
# -----------------------------------------------------------------------------
# Cosine-similarity threshold for clustering near-duplicate findings.
# DEDUP_SIMILARITY_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# Agent HTTP Service Ports (defaults shown; only change if rebinding ports)
# -----------------------------------------------------------------------------
# SCANNER_PORT=8090
# INVENTORY_PORT=8091
# THREAT_MODEL_PORT=8092
# ORCHESTRATOR_PORT=8093

# -----------------------------------------------------------------------------
# Inter-Agent URLs (set automatically by docker-compose)
# -----------------------------------------------------------------------------
# SCANNER_URL=http://scanner-agent:8090
# INVENTORY_URL=http://inventory-agent:8091
# THREAT_MODEL_URL=http://threat-model-agent:8092

# -----------------------------------------------------------------------------
# API Gateway configuration (optional overrides)
# -----------------------------------------------------------------------------
# COMPASS_ALLOWED_ORIGIN=http://localhost:3000
# COMPASS_WORKSPACE_ROOT=/workspace
# COMPASS_CLONE_TIMEOUT_S=300
# COMPASS_MAX_REPO_BYTES=524288000          # 500 MB
# ORCHESTRATOR_URL=http://orchestrator:8093
# ORCHESTRATOR_STREAM_TIMEOUT_S=3600

# -----------------------------------------------------------------------------
# MCP Server URLs (set automatically by docker-compose)
# -----------------------------------------------------------------------------
# MITRE_MCP_URL=http://mitre-mcp:8000/mcp
# SYFT_MCP_URL=http://syft-mcp:8080

# -----------------------------------------------------------------------------
# Fallback credentials for CLI / non-gateway invocation (optional)
# -----------------------------------------------------------------------------
# These are ONLY used if you run an agent directly (python scanner_agent.py)
# instead of going through the gateway. The gateway forwards per-request
# credentials over HTTP bodies and does not read these at all.
# LLM_PROVIDER=claude
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
