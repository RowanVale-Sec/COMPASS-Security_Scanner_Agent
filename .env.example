# =============================================================================
# COMPASS - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file with actual credentials to version control
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Selection
# -----------------------------------------------------------------------------
# Which LLM provider to use for all agents. Valid values: "azure" | "claude"
# (default: azure). Each provider requires its own credentials below.
LLM_PROVIDER=azure

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Required when LLM_PROVIDER=azure)
# -----------------------------------------------------------------------------
# Your Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Azure OpenAI deployment name for chat completions (default: gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure OpenAI deployment name used by Agent Framework
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure OpenAI embedding deployment (only needed if you revert to Azure
# embeddings; by default, deduplication uses local sentence-transformers).
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# -----------------------------------------------------------------------------
# Claude / Anthropic Configuration (Required when LLM_PROVIDER=claude)
# -----------------------------------------------------------------------------
# Your Anthropic API key
# CLAUDE_API_KEY=your-claude-api-key-here

# Claude model to use (default: claude-sonnet-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5

# Max tokens per Claude response (default: 4096; bump for long tool chains)
# CLAUDE_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Deduplication tuning
# -----------------------------------------------------------------------------
# Cosine-similarity threshold for clustering near-duplicate findings.
# MiniLM embeddings may need retuning vs. the original Azure-ada-002 setup.
# DEDUP_SIMILARITY_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# AWS S3 Configuration (Required)
# -----------------------------------------------------------------------------
# AWS Access Key ID for S3 storage
AWS_ACCESS_KEY_ID=your-aws-access-key-id

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# S3 Bucket name for storing agent results
S3_BUCKET=your-s3-bucket-name

# -----------------------------------------------------------------------------
# Scan Configuration
# -----------------------------------------------------------------------------
# Path to the folder to scan (default for Docker: /scan)
SCAN_FOLDER_PATH=/scan

# -----------------------------------------------------------------------------
# Agent HTTP Service Ports (defaults shown)
# -----------------------------------------------------------------------------
# SCANNER_PORT=8090
# INVENTORY_PORT=8091
# THREAT_MODEL_PORT=8092
# ORCHESTRATOR_PORT=8093

# -----------------------------------------------------------------------------
# Inter-Agent URLs (set automatically by docker-compose)
# -----------------------------------------------------------------------------
# SCANNER_URL=http://scanner-agent:8090
# INVENTORY_URL=http://inventory-agent:8091
# THREAT_MODEL_URL=http://threat-model-agent:8092

# -----------------------------------------------------------------------------
# MCP Server URLs (set automatically by docker-compose)
# -----------------------------------------------------------------------------
# MITRE_MCP_URL=http://mitre-mcp:8000/mcp
# SYFT_MCP_URL=http://syft-mcp:8080
